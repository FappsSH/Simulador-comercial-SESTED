{
    "functions": {
        "api/*.php": {
            "runtime": "vercel-php@0.9.0",
            "memory": 1024,
            "maxDuration": 10
        }
    },
    "routes": [
        { "src": "/api/(.*)", "dest": "/api/$1" },
        { "src": "/css/(.*)", "dest": "/css/$1" },
        { "src": "/js/(.*)", "dest": "/js/$1" },
        { "src": "/admin", "dest": "/admin.html" },
        { "src": "/(.*)", "dest": "/$1" }
    ]
}
