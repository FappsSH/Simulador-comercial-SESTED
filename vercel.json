{
    "functions": {
        "api/*.php": {
            "runtime": "vercel-php@0.9.0",
            "memory": 1024,
            "maxDuration": 10
        }
    },
    "routes": [
        { "src": "/api/(.*)", "dest": "/api/$1" },
        { "src": "/css/(.*)", "dest": "/public/css/$1" },
        { "src": "/js/(.*)", "dest": "/public/js/$1" },
        { "src": "/admin", "dest": "/public/admin.html" },
        { "src": "/(.*)", "dest": "/public/$1" }
    ]
}
